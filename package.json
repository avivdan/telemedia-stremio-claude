{
  "name": "telemedia-stremio",
  "version": "0.1.0",
  "description": "Stremio add-on that streams videos from Telegram chats (port of the Kodi plugin.video.telemedia 2.5.8).",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "login": "ts-node scripts/login.ts",
    "clean": "rimraf dist"
  },
  "keywords": [
    "stremio",
    "telegram",
    "gramjs",
    "telemedia"
  ],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "lru-cache": "^11.0.2",
    "stremio-addon-sdk": "^1.6.10",
    "telegram": "^2.25.15"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=18.17"
  }
}
